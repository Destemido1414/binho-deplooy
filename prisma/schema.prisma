datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id    String @id @default(cuid())
  name  String
  price Float
}
model QuoteRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}